# ============================================================
# pangpahu-dashboard 환경 변수 설정
# ============================================================

# --- OpenAI API ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Google OAuth2 / YouTube API ---
# client_secret JSON 파일 내용을 그대로 붙여넣기
GOOGLE_CLIENT_SECRET_JSON={"installed":{"client_id":"...","project_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_secret":"...","redirect_uris":["http://localhost"]}}

# --- YouTube OAuth2 Refresh Token ---
# 최초 인증 후 발급받은 refresh_token
# 채널별로 별도 토큰이 필요합니다
YOUTUBE_REFRESH_TOKEN_MYDACHSHUNDTRIO=your-refresh-token-for-mydachshundtrio
YOUTUBE_REFRESH_TOKEN_DRPANGPSYCH=your-refresh-token-for-drpangpsych

# --- 채널 선택 (GitHub Actions에서 사용) ---
# mydachshundtrio 또는 drpangpsych
TARGET_CHANNEL=mydachshundtrio
